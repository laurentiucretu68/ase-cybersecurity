{
  "name": "defi-heist-lab",
  "version": "1.0.0",
  "description": "Blockchain Security Lab - The DeFi Heist",
  "main": "index.js",
  "scripts": {
    "init:student": "node scripts/generate-instance.js",
    "init:batch": "node scripts/generate-batch-instances.js",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:all": "npm run test:reentrancy && npm run test:access",
    "test:reentrancy": "hardhat test test/test-reentrancy.js",
    "test:access": "hardhat test test/test-access-control.js",
    "deploy:all": "npm run deploy:vault && npm run deploy:admin && npm run deploy:forensics",
    "deploy:vault": "hardhat run scripts/deploy-simple-vault.js --network localhost",
    "deploy:admin": "hardhat run scripts/deploy-admin-vault.js --network localhost",
    "deploy:challenge1": "hardhat run scripts/setup-challenge1.js --network localhost",
    "deploy:forensics": "npm run deploy:challenge1",
    "inspect:tx": "node scripts/inspect-transaction.js",
    "trace:funds": "node scripts/trace-funds.js",
    "find:key": "bash scripts/find-private-key.sh",
    "grade:submission": "node scripts/grade-submissions.js",
    "console": "hardhat console --network localhost",
    "verify-setup": "node scripts/verify-setup.js",
    "clean:generated": "node scripts/clean-generated.js",
    "clean": "hardhat clean && rm -rf cache artifacts",
    "ganache": "./start-ganache.sh"
  },
  "keywords": [
    "blockchain",
    "security",
    "ethereum",
    "defi",
    "smart-contracts",
    "cybersecurity"
  ],
  "author": "Liviu Cretu <lcretu@bitdefender.com>",
  "license": "MIT",
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-etherscan": "^3.1.7",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "@typechain/ethers-v5": "^10.1.0",
    "@typechain/hardhat": "^6.1.2",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "chai": "^4.3.7",
    "ethereum-waffle": "^4.0.10",
    "ethers": "^5.7.2",
    "hardhat": "^2.14.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.2",
    "typechain": "^8.1.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.0",
    "dotenv": "^16.0.3"
  }
}
