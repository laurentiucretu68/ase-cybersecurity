# Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Network Configuration
NETWORK=localhost
RPC_URL=http://localhost:7545
CHAIN_ID=1337

# Deployment Configuration
GAS_PRICE=20000000000
GAS_LIMIT=6000000

# Optional: For testnet deployment (NOT needed for lab)
# INFURA_API_KEY=your_infura_key_here
# ALCHEMY_API_KEY=your_alchemy_key_here

# Optional: For contract verification on Etherscan (NOT needed for lab)
# ETHERSCAN_API_KEY=your_etherscan_key_here

# SECURITY WARNING:
# NEVER put private keys in .env files!
# Use hardware wallets or encrypted keystores for production
# For this lab, use Ganache's deterministic accounts instead
